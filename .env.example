# ==============================
# 2GIS Parser configuration
# ==============================

# Telegram bot token (get it from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# API key for 2GIS Places API (https://docs.2gis.com/en/platform-manager/subscription/keys)
DGIS_API_KEY=your_2gis_api_key_here

# Max result pages to request from 2GIS. Demo keys support up to 5 pages.
DGIS_MAX_PAGES=5

# Path to the SQLite database
DATABASE_PATH=./data/parser.db

# Directory for exported Excel files
OUTPUT_DIR=./exports
